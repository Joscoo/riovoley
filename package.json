    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@supabase/supabase-js": "^2.74.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gapi-script": "^1.2.0",
    "icons": "^1.0.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.7.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.3.0",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.13"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "cross-env CI=false react-scripts build",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:android": "npm run mobile:sync && npx cap open android",
    "check:copy-quality": "node scripts/copyQualityCheck.js",
    "test": "react-scripts test",
    "test:contracts": "cross-env CI=true react-scripts test src/features/reporting/infrastructure/repositories/supabaseReportingRepository.contract.test.js src/shared/infrastructure/auth/deleteAuthUserById.test.js",
    "eject": "react-scripts eject",
    "e2e": "playwright test",
    "e2e:smoke:roles": "playwright test tests/e2e/roles.panels-navigation.smoke.spec.js --project=desktop-1440",
    "e2e:smoke:roles:strict": "node scripts/e2e/runRolesSmokeStrict.js",
    "e2e:filters-sorting": "playwright test tests/e2e/filters-sorting.tables.spec.js --project=desktop-1440",
    "e2e:filters-sorting:users": "playwright test tests/e2e/filters-sorting.user-management.spec.js --project=desktop-1440",
    "e2e:filters-sorting:phase2": "playwright test tests/e2e/filters-sorting.phase2-lists.spec.js --project=desktop-1440",
    "e2e:filters-sorting:physical": "playwright test tests/e2e/filters-sorting.physical-tests.spec.js --project=desktop-1440",
    "e2e:filters-sorting:all": "playwright test tests/e2e/filters-sorting.tables.spec.js tests/e2e/filters-sorting.user-management.spec.js tests/e2e/filters-sorting.phase2-lists.spec.js tests/e2e/filters-sorting.physical-tests.spec.js --project=desktop-1440",
    "e2e:smoke:public": "playwright test tests/e2e/responsive.smoke.spec.js --project=desktop-1440 --grep \"public route responsive guard\"",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
