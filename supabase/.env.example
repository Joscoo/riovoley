# Variables de entorno para Edge Functions
# Copiar a .env.local y completar con valores reales

# API Key de Resend (Obtener en: https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email desde el cual se enviaran los correos
FROM_EMAIL=noreply@tudominio.com

# URL de tu proyecto Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opcional: secreto adicional para invocaciones de scheduler externo
REPORTS_SCHEDULER_SECRET=define_un_secreto_fuerte

# Firebase Cloud Messaging para push Android
FCM_PROJECT_ID=tu-proyecto-firebase
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxx@tu-proyecto.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
