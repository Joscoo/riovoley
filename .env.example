# Variables de entorno para Supabase - Archivo de ejemplo
# Copia este archivo como .env.local y completa con tus valores reales

REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# URL publica oficial de la app para enlaces de recuperacion y login.
# Produccion: https://riovoley.com
REACT_APP_APP_URL=https://riovoley.com

# Clave para cifrado en cliente de PII (email/telefono).
# Recomendado: minimo 32 caracteres aleatorios.
REACT_APP_PII_ENCRYPTION_KEY=replace_with_a_strong_random_secret

# ==============================================
# WHATSAPP BUSINESS API CONFIGURATION
# ==============================================

# Token de acceso permanente de WhatsApp Business API
# Obtenerlo desde: Meta Business Manager > WhatsApp > Configuración > Tokens de acceso
REACT_APP_WHATSAPP_ACCESS_TOKEN=tu_access_token_aqui

# ID del número de teléfono de WhatsApp Business
# Obtenerlo desde: Meta Business Manager > WhatsApp > Números de teléfono
REACT_APP_WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui

# ID de la cuenta comercial de WhatsApp
# Obtenerlo desde: Meta Business Manager > Configuración empresarial
REACT_APP_WHATSAPP_BUSINESS_ACCOUNT_ID=tu_business_account_id_aqui

# ==============================================
# NUMEROS DE TELEFONO DEL CLUB
# ==============================================

# Número de administración del club (con código de país)
REACT_APP_CLUB_ADMIN_PHONE=5491123456789

# Número de entrenadores (con código de país)
REACT_APP_CLUB_COACH_PHONE=5491123456790

# Número de emergencias (con código de país)
REACT_APP_CLUB_EMERGENCY_PHONE=5491123456791