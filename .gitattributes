# Control de finales de línea
# Normalizar todos los archivos de texto a LF en el repositorio
* text=auto eol=lf

# Archivos específicos de código
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.sh text eol=lf

# Archivos de configuración
.gitignore text eol=lf
.gitattributes text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Archivos binarios
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
