# ========================================
# WhatsApp Business API - Meta Cloud API
# ========================================

# URL publica de la app para construir enlaces de recuperacion.
# En local normalmente: http://localhost:3000
REACT_APP_APP_URL=http://localhost:3000

# Access Token (obtén en Meta Business Manager > WhatsApp > Configuración > Tokens)
REACT_APP_WHATSAPP_ACCESS_TOKEN=

# Phone Number ID (obtén en Meta Business Manager > WhatsApp > Configuración)
REACT_APP_WHATSAPP_PHONE_NUMBER_ID=

# Business Account ID (obtén en Meta Business Manager > Configuración empresarial)
REACT_APP_WHATSAPP_BUSINESS_ACCOUNT_ID=

# ========================================
# Números de Contacto del Club
# ========================================

# Número principal (administración) - Formato: 5491123456789
REACT_APP_CLUB_ADMIN_PHONE=

# Número de entrenadores
REACT_APP_CLUB_COACH_PHONE=

# Número de emergencias
REACT_APP_CLUB_EMERGENCY_PHONE=

# ========================================
# INSTRUCCIONES:
# ========================================
# 1. Renombra este archivo a: .env.local
# 2. Completa los valores sin comillas
# 3. NO subas este archivo a Git (ya está en .gitignore)
# 4. Reinicia la aplicación después de configurar
# 5. Formato números: 5491123456789 (sin +, sin espacios)
#
# Para obtener las credenciales:
# https://business.facebook.com
# ========================================
